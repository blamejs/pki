# Deny all dotfiles by default; allow-list specific ones below.
# Catches .env*, .aws/, .ssh/, .npmrc-with-tokens, .vscode/, .idea/,
# .bash_history, .DS_Store, AI-tooling scratch, and anything else
# that conventionally lives in a dotfile we don't intend to ship.
.*

# Dotfiles we DO want tracked
!.gitignore
!.gitattributes
!.github/
!.editorconfig
!.dockerignore
!.hadolint.yaml
!.nvmrc
!.npmrc
!.gitleaks.toml
!.pinact.yaml
# Vendor-data integrity surface — pubkey ships in tarball so operators
# verify .data.js signatures against the maintainer's pinned key.
!lib/vendor/.vendor-data-pubkey

# Build / dependencies
node_modules/
dist/
build/
out/
coverage/
*.tsbuildinfo

# Runtime / logs
*.log
*.pid
*.pid.lock
tmp/

# OS junk (non-dotfile)
Thumbs.db
desktop.ini

# Editor scratch (non-dotfile)
*.swp
*.swo
*~

# Credential / key material — belt-and-braces over .*
*.pem
*.key
*.crt
*.cert
*.p12
*.pfx
secrets.json
credentials.json
id_rsa*
id_ed25519*

# Vendored trust bundles / test vectors that MUST track are re-allowed
# explicitly. The blanket *.pem / *.crt rules above guard against
# accidental commit of OPERATOR-PRIVATE material; any published test
# vectors or trust roots that ship with the package opt back in here.
!lib/vendor/*.pem
!lib/vendor/*.crt
!test/fixtures/*.pem
!test/fixtures/*.crt

# Backup / patch artifacts
*.bak
*.orig
*.rej

# Dev/example lockfiles ARE committed (root, examples/wiki, fuzz) so CI's
# `npm ci` pins the reviewed dev-tool versions with integrity hashes and
# OpenSSF Scorecard sees a pinned install. This does NOT relax the zero-npm-
# RUNTIME-deps rule — the toolkit ships zero runtime deps (everything
# vendored under lib/vendor/); these lockfiles are dev/example-only and are
# excluded from the published tarball's `files` allowlist.

# Example-app per-instance runtime state.
examples/*/data/
examples/*/data-e2e/
examples/*/public/dist/

# CycloneDX SBOM — generated by the npm-publish workflow at publish time
# and bundled into the tarball; never committed.
sbom.cdx.json
sbom.vendored.cdx.json

# Local-only release tooling — gen-changelog runs against an operator's
# clone; CHANGELOG.md ships hand-curated from the release commit.
scripts/gen-changelog.js

# Maintainer-local design notes — upstream-comparison grounding, roadmap
# rationale, and internal specs. GOVERNANCE.md references memory/specs/ as
# maintainer-local; the operator-facing roadmap lives in ROADMAP.md.
memory/

# Test-runner diagnostics (sync-fd persisted, read on failure).
.test-output/
